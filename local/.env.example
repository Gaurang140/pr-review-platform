# copy this to local/.env and fill in the keys you generate.
# local/.env is gitignored. compose reads this file for every service.

# --- you generate these ---
# groq: free key at console.groq.com
GROQ_API_KEY=
# github app (only needed for real PR reviews, see local/README.md)
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# the app private key is multiline, so it is handled separately at the
# real-PR step (mounted as a file) - leave blank for local bring-up.
GITHUB_APP_PRIVATE_KEY=
# optional tracing - leave blank to disable langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# --- set for you (local stand-ins, no need to change) ---
DATABASE_URL=postgresql+asyncpg://dbadmin:localdevpassword@postgres:5432/codereviewer
REDIS_URL=redis://redis:6379/0
WEBHOOK_SERVICE_URL=http://webhook:8001
ORCHESTRATOR_SERVICE_URL=http://orchestrator:8002
REVIEWER_SERVICE_URL=http://reviewer:8003
LEARNER_SERVICE_URL=http://learner:8004
REVIEW_MODEL=llama-3.3-70b-versatile

# minio (s3 stand-in) - optional, the review flow does not use it
AWS_ENDPOINT_URL=http://minio:9000
AWS_S3_BUCKET=ai-code-reviewer-reports
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
