# copy this to local/.env and fill in the keys you generate.
# local/.env is gitignored. sync-secret.sh reads it into the app-secrets secret.
# non-secret config (redis url, service urls, model...) is NOT here - it lives in
# infra/k8s/overlays/local/configmap.yaml.

# --- you generate these ---
# groq: free key at console.groq.com
GROQ_API_KEY=
# github app (only needed for real PR reviews)
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
# the app private key is multiline, so it is handled separately: drop the .pem
# into local/ and sync-secret.sh picks it up. leave this blank.
GITHUB_APP_PRIVATE_KEY=
# optional tracing - leave blank to disable langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- set for you (local stand-ins, no need to change) ---
# postgres stand-in for RDS
DATABASE_URL=postgresql+asyncpg://dbadmin:localdevpassword@postgres:5432/codereviewer
# minio stand-in for S3 (the review flow does not use it)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
